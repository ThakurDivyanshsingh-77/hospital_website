PORT=5000
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=careconnect
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
# Optional (alternative to MYSQL_* vars):
# MYSQL_URL=mysql://root:your_mysql_password@127.0.0.1:3306/careconnect
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173,http://localhost:8080
SEED_ADMIN_EMAIL=admin@careconnect.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=CareConnect Admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
MAIL_FROM="CareConnect <no-reply@yourdomain.com>"
FEEDBACK_TO_EMAIL=you@example.com
